{
    "version": "build-2026-07-18-21-59-n125668",
    "description": "FFmpeg nonfree shared build from nanake tinderbox",
    "homepage": "https://github.com/nanake/ffmpeg-tinderbox",
    "license": "GPL-3.0",

    "architecture": {
        "64bit": {
            "url": "https://github.com/nanake/ffmpeg-tinderbox/releases/download/build-2026-07-18-21-59-n125668/ffmpeg-win64-nonfree-shared.tar.zst"
        }
    },

    "installer": {
        "script": [
            "$root = Get-ChildItem \"$dir\" -Directory | Where-Object { Test-Path \"$($_.FullName)\\bin\\ffmpeg.exe\" }",
            "if ($root) {",
            "    Move-Item \"$($root.FullName)\\*\" \"$dir\" -Force",
            "    Remove-Item \"$($root.FullName)\" -Recurse -Force",
            "}"
        ]
    },

    "bin": [
        [
            "bin\\ffmpeg.exe",
            "ffmpeg"
        ],
        [
            "bin\\ffprobe.exe",
            "ffprobe"
        ],
        [
            "bin\\ffplay.exe",
            "ffplay"
        ]
    ],

    "checkver": {
        "url": "https://api.github.com/repos/nanake/ffmpeg-tinderbox/releases/latest",
        "jsonpath": "$.tag_name"
    },

    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nanake/ffmpeg-tinderbox/releases/download/$version/ffmpeg-win64-nonfree-shared.tar.zst"
            }
        }
    }
}
